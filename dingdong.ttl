# dingdong.ttl — DingDong Delay LV2 Plugin Descriptor

@prefix lv2:   <http://lv2plug.in/ns/lv2core#> .
@prefix atom:  <http://lv2plug.in/ns/ext/atom#> .
@prefix midi:  <http://lv2plug.in/ns/ext/midi#> .
@prefix urid:  <http://lv2plug.in/ns/ext/urid#> .
@prefix units: <http://lv2plug.in/ns/extensions/units#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix doap:  <http://usefulinc.com/ns/doap#> .
@prefix pg:    <http://lv2plug.in/ns/ext/port-groups#> .

<urn:dingdong:DingDongDelay>
    a lv2:Plugin, lv2:DelayPlugin ;
    doap:name     "DingDong Delay" ;
    doap:license  <https://opensource.org/licenses/MIT> ;
    rdfs:comment  "Stereo ping-pong delay + shimmer. MIDI tap tempo. Analog warmth." ;
    lv2:requiredFeature urid:map ;
    lv2:optionalFeature lv2:hardRTCapable ;

    lv2:port
    [
        a lv2:AudioPort, lv2:InputPort ;
        lv2:index 0 ; lv2:symbol "audio_in_l" ; lv2:name "Audio In L" ;
        lv2:designation pg:left
    ] , [
        a lv2:AudioPort, lv2:InputPort ;
        lv2:index 1 ; lv2:symbol "audio_in_r" ; lv2:name "Audio In R" ;
        lv2:designation pg:right
    ] , [
        a lv2:AudioPort, lv2:OutputPort ;
        lv2:index 2 ; lv2:symbol "audio_out_l" ; lv2:name "Audio Out L" ;
        lv2:designation pg:left
    ] , [
        a lv2:AudioPort, lv2:OutputPort ;
        lv2:index 3 ; lv2:symbol "audio_out_r" ; lv2:name "Audio Out R" ;
        lv2:designation pg:right
    ] , [
        a atom:AtomPort, lv2:InputPort ;
        atom:bufferType atom:Sequence ;
        atom:supports   midi:MidiEvent ;
        lv2:index 4 ; lv2:symbol "midi_in" ; lv2:name "MIDI In" ;
        lv2:designation lv2:control
    ] , [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index 5 ; lv2:symbol "level" ; lv2:name "Level" ;
        lv2:default 0.8 ; lv2:minimum 0.0 ; lv2:maximum 1.0
    ] , [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index 6 ; lv2:symbol "mix" ; lv2:name "Mix" ;
        lv2:default 0.5 ; lv2:minimum 0.0 ; lv2:maximum 1.0
    ] , [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index 7 ; lv2:symbol "decay" ; lv2:name "Decay" ;
        lv2:default 0.4 ; lv2:minimum 0.0 ; lv2:maximum 0.95
    ] , [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index 8 ; lv2:symbol "hp_freq" ; lv2:name "HP Freq" ;
        lv2:default 80.0 ; lv2:minimum 20.0 ; lv2:maximum 2000.0 ;
        units:unit units:hz
    ] , [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index 9 ; lv2:symbol "lp_freq" ; lv2:name "LP Freq" ;
        lv2:default 6000.0 ; lv2:minimum 500.0 ; lv2:maximum 20000.0 ;
        units:unit units:hz
    ] , [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index 10 ; lv2:symbol "delay_ms" ; lv2:name "Delay Time" ;
        lv2:default 500.0 ; lv2:minimum 50.0 ; lv2:maximum 2000.0 ;
        units:unit units:ms
    ] , [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index 11 ; lv2:symbol "shimmer_mix" ; lv2:name "Shimmer Mix" ;
        lv2:default 0.0 ; lv2:minimum 0.0 ; lv2:maximum 1.0
    ] , [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index 12 ; lv2:symbol "shimmer_pitch" ; lv2:name "Shimmer Pitch" ;
        lv2:default 0 ; lv2:minimum 0 ; lv2:maximum 2 ;
        lv2:portProperty lv2:integer, lv2:enumeration ;
        lv2:scalePoint [ rdfs:label "+Octave" ; rdf:value 0 ] ;
        lv2:scalePoint [ rdfs:label "+5th"    ; rdf:value 1 ] ;
        lv2:scalePoint [ rdfs:label "-Octave" ; rdf:value 2 ]
    ] , [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index 13 ; lv2:symbol "stereo" ; lv2:name "Stereo" ;
        lv2:default 1 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:integer, lv2:enumeration ;
        lv2:scalePoint [ rdfs:label "Mono"            ; rdf:value 0 ] ;
        lv2:scalePoint [ rdfs:label "Stereo/Ping-pong" ; rdf:value 1 ]
    ] .
